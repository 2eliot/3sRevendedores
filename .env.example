# ============================================================
# Variables de entorno para 3sRevendedores — VPS PostgreSQL
# ============================================================

# === APP ===
SECRET_KEY=tu_clave_secreta_aqui_cambiar_en_produccion
FLASK_ENV=production

# === BASE DE DATOS (PostgreSQL) ===
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/revendedores

# === ADMIN ===
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=CambiarEstaContraseña!
ADMIN_USER_IDS=1
ADMIN_EMAILS=admin@tudominio.com

# === SERVIDOR ===
PORT=8000
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=120

# === CORREO (opcional) ===
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=tu_password_de_aplicacion

# === BINANCE PAY ===
BINANCE_API_KEY=tu_api_key_de_binance
BINANCE_API_SECRET=tu_api_secret_de_binance
BINANCE_PAY_ID=tu_binance_pay_id
BINANCE_PROXY=
RECARGA_BONUS_PERCENT=3
RECARGA_EXPIRATION_MINUTES=30
RECARGA_MIN_USDT=1
RECARGA_MAX_USDT=50000

# === GAMEPOINT CLUB (proveedor de recargas) ===
GAMECLUB_BASE_URL=https://api.gamepointclub.net
GAMECLUB_PARTNERID=tu_partner_id
GAMECLUB_SECRET=tu_secret
# GAMECLUB_PROXY=http://proxy:port  (opcional)

# === BLOOD STRIKE ===
BLOODSTRIKE_PRODUCT_ID=155
BLOODSTRIKE_PROFIT_USD=0.11
# BLOODSTRIKE_USD_TO_MYR_RATE=4.47  (opcional, auto-sync)

# === MAPEO REVENDEDORES (auto-recharge) ===
REVENDEDORES_BASE_URL=https://tu-revendedor.com
REVENDEDORES_API_KEY=tu_api_key_revendedor

# === API EXTERNA (recibir órdenes de otras webs) ===
REVENDEDORES_API_TOKEN=tu_token_para_recibir_ordenes
WEBB_API_KEY=tu_webb_api_key
WEBB_FF_TIPO=freefire_id

# === VPS REDEEM ===
VPS_REDEEM_URL=http://tu-vps-ip:5000/redeem

# === INEFABLE SHOP (legacy) ===
INEFABLE_USUARIO=inefableshop
INEFABLE_CLAVE=tu_clave

# === ZONA HORARIA ===
DEFAULT_TZ=America/Caracas

# === SYNC ===
DYN_SYNC_INTERVAL_HOURS=6.0
